# Environment Variables
# Copy to .env.local and fill in real values. Never commit .env.local.

# Supabase - get these from your project's Settings -> API page
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-side only - NEVER expose to the client, log, or commit
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gemini - used for chat/tool-calling and embeddings in Phases 2-4
GEMINI_API_KEY=your-gemini-api-key

# Discord webhook for send_channel_summary tool (Phase 4)
DISCORD_WEBHOOK_URL=your-discord-webhook-url